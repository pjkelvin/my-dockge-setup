sudo apt update && sudo apt upgrade -y
sudo timedatectl set-timezone Asia/Manila
sudo apt-get install nano
sudo apt-get install htop
sudo apt-get install iputils-ping

# 1. Install Docker using the official convenience script 
curl -fsSL https://get.docker.com -o get-docker.sh
sudo sh get-docker.sh
rm get-docker.sh # Clean up the installer script 

# 2. Manage Docker as non-root user - - this allow user to run command without using sudo
sudo usermod -aG docker $USER
newgrp docker

# 3. Create Dockge directories and set permissions 
sudo mkdir -p /opt/stacks /opt/dockge
sudo chown -R $USER:$USER /opt/stacks /opt/dockge 
cd /opt/dockge

# dockge script, compose
curl https://raw.githubusercontent.com/pjkelvin/my-dockge-setup/master/compose.yaml --output compose.yaml

#verify the compose.yaml
cat compose.yaml

# start dockge
docker compose up -d

#verify the docker
docker ps -a

